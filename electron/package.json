{
  "name": "Pull Request Tracker Dashboard",
  "version": "1.0.0",
  "description": "PR Tracker - GitHub Pull Request metrics dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:frontend": "cd ../frontend && npx vite build --mode electron",
    "build:backend": "cd ../backend/local && pyinstaller --onefile --name pr-tracker-api --add-data '../db/schema.sql:db' --hidden-import duckdb server.py",
    "build:backend:mac": "cd ../backend/local && pyinstaller --onefile --name pr-tracker-api --add-data '../db/schema.sql:db' --hidden-import duckdb --target-arch universal2 server.py",
    "build": "npm run build:frontend && npm run build:backend && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.1.1",
    "get-port": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.prtracker.app",
    "productName": "Pull Request Tracker Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend-dist/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/local/dist/pr-tracker-api",
        "to": "backend/pr-tracker-api"
      },
      {
        "from": "../backend/db/schema.sql",
        "to": "backend/schema.sql"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "icons/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "icon": "icons"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icons/icon.ico"
    }
  }
}
