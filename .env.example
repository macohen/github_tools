# GitHub Configuration
# Create a personal access token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=your_github_token_here

# Repository to track
GITHUB_REPO_OWNER=awslabs
GITHUB_REPO_NAME=aws-athena-query-federation

# Database configuration
DB_PATH=backend/local/pr_tracker.duckdb

# API configuration
API_URL=http://localhost:5001/api

# Optional: Quip integration (if using)
# QUIP_API_TOKEN=your_quip_token_here
# QUIP_DOC_ID=your_quip_doc_id_here
